# ─── Database ────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=loklflow
DATABASE_PASSWORD=loklflow
DATABASE_NAME=loklflow_db
DATABASE_URL=postgresql://loklflow:loklflow@localhost:5432/loklflow_db

# ─── Redis ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=change-this-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── App ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Next.js ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
